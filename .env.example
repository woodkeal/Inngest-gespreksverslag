# ─── Inngest ───────────────────────────────────────────────────────────────────
INNGEST_DEV=1               # Zet op 1 voor lokale ontwikkeling — geen keys nodig
INNGEST_SIGNING_KEY=        # Vereist voor productie (van Inngest Cloud dashboard)
INNGEST_EVENT_KEY=          # Vereist voor productie (van Inngest Cloud dashboard)

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # sk-ant-...

# ─── OpenAI (alleen voor Whisper audio transcriptie) ───────────────────────────
OPENAI_API_KEY=             # sk-...

# ─── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=         # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=     # whatsapp:+14155238886

# ─── E-mail (SendGrid — gratis tier = 100 e-mails/dag) ────────────────────────
SENDGRID_API_KEY=           # SG.xxxxx van sendgrid.com
EMAIL_FROM=noreply@jouwdomein.nl
EMAIL_FROM_NAME=Gespreksverslag Bot

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=https://jouw-ngrok-url.ngrok.io  # Voor Twilio signature validatie

# ─── Flow control ──────────────────────────────────────────────────────────────
HITL_TIMEOUT=10m            # Inngest TimeStr formaat
MAX_MESSAGES_PER_HOUR=20
