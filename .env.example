# ─── Inngest ───────────────────────────────────────────────────────────────────
# Lokaal: zet INNGEST_DEV=1 en laat SIGNING_KEY/EVENT_KEY leeg
# Productie: verwijder INNGEST_DEV, vul beide keys in vanuit Inngest Cloud dashboard
INNGEST_DEV=1               # VERWIJDER DIT IN PRODUCTIE
INNGEST_SIGNING_KEY=        # Vereist voor productie
INNGEST_EVENT_KEY=          # Vereist voor productie

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # sk-ant-...

# ─── OpenAI (alleen voor Whisper audio transcriptie) ───────────────────────────
OPENAI_API_KEY=             # sk-...

# ─── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=         # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=     # whatsapp:+14155238886

# ─── E-mail (SendGrid — gratis tier = 100 e-mails/dag) ────────────────────────
SENDGRID_API_KEY=           # SG.xxxxx van sendgrid.com
EMAIL_FROM=noreply@jouwdomein.nl
EMAIL_FROM_NAME=Gespreksverslag Bot

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production         # Gebruik 'production' in productie (activeert Twilio signature validatie)
PUBLIC_BASE_URL=            # Vul de publieke URL van je server in (bijv. https://jouw-app.railway.app)

# ─── Flow control ──────────────────────────────────────────────────────────────
HITL_TIMEOUT=10m            # Inngest TimeStr formaat
MAX_MESSAGES_PER_HOUR=20

# ─── Geheugen (Upstash Redis — gratis tier: 10.000 calls/dag, 256 MB) ──────────
# Maak een gratis database aan op upstash.com → kopieer REST URL + token
UPSTASH_REDIS_REST_URL=     # https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=   # token van Upstash dashboard
